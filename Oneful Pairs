import java.util.Scanner;

class Codechef
{
    public static void main (String[] args)
    {
        Scanner sc = new Scanner(System.in);
        int a = sc.nextInt();
        int b = sc.nextInt();
        
        // Use the standard '*' operator for multiplication in Java
        int s = a + b + (a * b);
        
        if (s == 111)
        {
            System.out.println("Yes");
        }
        else
        {
            System.out.println("No");
        }
        
        sc.close();
    }
}
