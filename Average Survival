import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
    public static void main (String[] args) throws java.lang.Exception
    {
        Scanner sc = new Scanner(System.in);
        
        if (sc.hasNextInt()) {
            int T = sc.nextInt();
            
            while (T-- > 0) {
                int N = sc.nextInt();
                int[] A = new int[N];
                
                int maxVal = Integer.MIN_VALUE;
                
                for (int i = 0; i < N; i++) {
                    A[i] = sc.nextInt();
                    if (A[i] > maxVal) {
                        maxVal = A[i];
                    }
                }
                
                // Count how many elements equal the maximum value
                int countMax = 0;
                for (int i = 0; i < N; i++) {
                    if (A[i] == maxVal) {
                        countMax++;
                    }
                }
                
                // The minimum final length will always be the count of maximum elements
                System.out.println(countMax);
            }
        }
        
        sc.close();
    }
}
