import java.util.*;
import java.io.*;

public class Solution {
    public static int maxAreaContainer(ArrayList<Integer> arr) {
        int left = 0;
        int right = arr.size() - 1;
        int maxArea = 0;

        while (left < right) {
            // Calculate height and width
            int h1 = arr.get(left);
            int h2 = arr.get(right);
            int height = Math.min(h1, h2);
            int width = right - left;
            
            // Calculate current area and update max
            int currentArea = height * width;
            maxArea = Math.max(maxArea, currentArea);

            // Move the pointer of the smaller line inward
            if (h1 < h2) {
                left++;
            } else {
                right--;
            }
        }
        
        return maxArea;
    }
}
