import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

class Solution {
    public int minDeletions(int[] arr) {
        int n = arr.length;
        if (n <= 1) return 0;

        // Stores the active strictly increasing sequence candidates
        List<Integer> lis = new ArrayList<>();

        for (int num : arr) {
            // Binary search to find the position of the first element >= num
            int idx = Collections.binarySearch(lis, num);

            // Collections.binarySearch returns (-(insertion point) - 1) if not found
            if (idx < 0) {
                idx = -(idx + 1);
            }

            // Replace element if idx is within bounds, else append
            if (idx < lis.size()) {
                lis.set(idx, num);
            } else {
                lis.add(num);
            }
        }

        // Minimum deletions needed = Total elements - LIS length
        return n - lis.size();
    }
}
