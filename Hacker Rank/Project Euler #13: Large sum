import java.io.*;
import java.util.*;
import java.math.BigInteger;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (!sc.hasNextInt()) return;
        
        int n = sc.nextInt();
        BigInteger sum = BigInteger.ZERO;
        
        for (int i = 0; i < n; i++) {
            // Read each 50-digit number as a string and add it to the running sum
            sum = sum.add(new BigInteger(sc.next()));
        }
        
        // Convert the total sum to a string
        String sumStr = sum.toString();
        
        // Print only the first 10 digits of the final sum
        System.out.println(sumStr.substring(0, 10));
    }
}
