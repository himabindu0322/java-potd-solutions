import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        
        String[] names = new String[n];
        for (int i = 0; i < n; i++) {
            names[i] = sc.next();
        }
        
        // Sort names alphabetically
        Arrays.sort(names);
        
        // Map names to their 1-indexed sorted position
        Map<String, Integer> nameToPosition = new HashMap<>();
        for (int i = 0; i < n; i++) {
            nameToPosition.put(names[i], i + 1);
        }
        
        if (sc.hasNextInt()) {
            int q = sc.nextInt();
            for (int i = 0; i < q; i++) {
                String queryName = sc.next();
                
                // Calculate alphabetical value sum
                long charSum = 0;
                for (int j = 0; j < queryName.length(); j++) {
                    charSum += (queryName.charAt(j) - 'A' + 1);
                }
                
                // Retrieve the 1-indexed sorted rank position
                int position = nameToPosition.getOrDefault(queryName, 0);
                
                // Total score
                long score = position * charSum;
                System.out.println(score);
            }
        }
        sc.close();
    }
}
