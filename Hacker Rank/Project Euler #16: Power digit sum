import java.io.*;
import java.util.*;
import java.math.BigInteger;

public class Solution {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        if (scanner.hasNextInt()) {
            int t = scanner.nextInt();
            
            while (t-- > 0) {
                int n = scanner.nextInt();
                
                // Calculate 2^N using BigInteger
                BigInteger power = BigInteger.valueOf(2).pow(n);
                
                // Convert the large number to a string to process digits
                String digits = power.toString();
                int digitSum = 0;
                
                // Sum up the numerical value of each character digit
                for (int i = 0; i < digits.length(); i++) {
                    digitSum += digits.charAt(i) - '0';
                }
                
                System.out.println(digitSum);
            }
        }
        
        scanner.close();
    }
}
