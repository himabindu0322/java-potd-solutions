import java.util.*;

class Solution {
    public int countCompleteComponents(int n, int[][] edges) {
        // Step 1: Build the adjacency list
        List<List<Integer>> adj = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            adj.add(new ArrayList<>());
        }
        for (int[] edge : edges) {
            adj.get(edge[0]).add(edge[1]);
            adj.get(edge[1]).add(edge[0]);
        }

        boolean[] visited = new boolean[n];
        int completeComponentsCount = 0;

        // Step 2: Traverse each component
        for (int i = 0; i < n; i++) {
            if (!visited[i]) {
                // Track total vertices and edges in the current component
                int vertexCount = 0;
                int edgeCount = 0;

                Queue<Integer> queue = new LinkedList<>();
                queue.offer(i);
                visited[i] = true;

                while (!queue.isEmpty()) {
                    int curr = queue.poll();
                    vertexCount++;
                    // Sum up the degrees of all vertices in this component
                    edgeCount += adj.get(curr).size();

                    for (int neighbor : adj.get(curr)) {
                        if (!visited[neighbor]) {
                            visited[neighbor] = true;
                            queue.offer(neighbor);
                        }
                    }
                }

                // Since it's an undirected graph, each edge is counted twice 
                // (once from each endpoint). We divide by 2 to get the actual edge count.
                edgeCount /= 2;

                // Check if the component is complete
                if (edgeCount == (vertexCount * (vertexCount - 1)) / 2) {
                    completeComponentsCount++;
                }
            }
        }

        return completeComponentsCount;
    }
}
