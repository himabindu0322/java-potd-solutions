import java.io.*;
import java.util.*;

public class Main {
    public static void main(String[] args) throws IOException {
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        String line = br.readLine();
        if (line == null || line.trim().isEmpty()) {
            System.out.println(0);
            return;
        }

        // Parse all node values from the level order input string
        String[] tokens = line.trim().split("\\s+");
        List<Integer> values = new ArrayList<>();
        
        for (String token : tokens) {
            int val = Integer.parseInt(token);
            // Ignore the null node indicators (-1)
            if (val != -1) {
                values.add(val);
            }
        }

        // Sort unique values in ascending order
        Collections.sort(values);

        long totalSum = 0;
        long MOD = 1_000_000_007L;
        int m = values.size();

        // Calculate the contribution of each element: value * its 1-based index position
        for (int i = 0; i < m; i++) {
            long count = i + 1;
            long value = values.get(i);
            long contribution = (value * count) % MOD;
            totalSum = (totalSum + contribution) % MOD;
        }

        System.out.println(totalSum);
    }
}
