import java.util.*;

public class Main {
    public static int play_game(int[] marbles) {
        // Max Heap to store the marbles in descending order
        PriorityQueue<Integer> maxHeap = new PriorityQueue<>(Collections.reverseOrder());

        for (int marble : marbles) {
            maxHeap.add(marble);
        }

        // Process until 1 or 0 elements remain
        while (maxHeap.size() > 1) {
            int max1 = maxHeap.poll();
            int max2 = maxHeap.poll();

            int sum = max1 + max2;

            // Check if the mean is a whole number (sum is even)
            if (sum % 2 == 0) {
                int mean = sum / 2;
                maxHeap.add(mean);
            }
            // If mean is not a whole number, both elements are destroyed
        }

        // Return the remaining marble count or 0 if empty
        return maxHeap.isEmpty() ? 0 : maxHeap.peek();
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;

        int n = scanner.nextInt();
        int[] marbles = new int[n];
        for (int i = 0; i < n; i++) {
            marbles[i] = scanner.nextInt();
        }

        int result = play_game(marbles);
        System.out.println(result);
    }
}
