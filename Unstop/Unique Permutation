import java.util.Scanner;

public class Main {
    public static int anotherPermutationProblem(int[] nums, int K) {
        int n = nums.length;
        
        // Base case: If array has 1 or fewer elements, 0 operations needed
        if (n <= 1) {
            return 0;
        }
        
        // Integer ceiling division for (n - 1) / (K - 1)
        return (n - 1 + K - 2) / (K - 1);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (!sc.hasNextInt()) return;
        
        int n = sc.nextInt();
        int[] nums = new int[n];
        for (int i = 0; i < n; i++) {
            nums[i] = sc.nextInt();
        }
        int K = sc.nextInt();
        
        int result = anotherPermutationProblem(nums, K);
        System.out.println(result);
    }
}
