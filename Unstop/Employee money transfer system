import java.util.*;

public class Main {
    public static List<Boolean> canPaySalaries(int companyMoney, List<String> employeeNames, List<Integer> employeeSalaries) {
        List<Boolean> result = new ArrayList<>();
        
        // Loop through each salary sequentially
        for (int salary : employeeSalaries) {
            // Check if current company money can cover the salary
            if (companyMoney >= salary) {
                companyMoney -= salary; // Deduct the amount
                result.add(true);
            } else {
                result.add(false); // Insufficient funds, balance remains unchanged
            }
        }
        
        return result;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int companyMoney = sc.nextInt();
        int employeeCount = sc.nextInt();
        sc.nextLine(); // Consume the leftover newline
        
        List<String> employeeNames = Arrays.asList(sc.nextLine().split(" "));
        List<Integer> employeeSalaries = new ArrayList<>();
        for (String s : sc.nextLine().split(" ")) {
            if (!s.trim().isEmpty()) {
                employeeSalaries.add(Integer.parseInt(s));
            }
        }

        List<Boolean> result = canPaySalaries(companyMoney, employeeNames, employeeSalaries);

        for (int i = 0; i < result.size(); i++) {
            System.out.print(result.get(i));
            if (i < result.size() - 1) {
                System.out.print(" ");
            }
        }
    }
}
