import java.util.Scanner;

public class Main {
    public static int calculate_max_score(int n, String s) {
        long MOD = 1_000_000_007L;
        
        // Step 1: Count frequencies of each character (Counting Sort)
        int[] counts = new int[26];
        for (int i = 0; i < n; i++) {
            counts[s.charAt(i) - 'a']++;
        }
        
        long totalScore = 0;
        long pow26 = 1; // Represents 26^i % MOD, starting at 26^0 = 1
        
        // Step 2: Traverse characters from 'a' to 'z' (increasing order)
        // This ensures smaller characters get smaller powers, and larger characters get larger powers
        for (int c = 0; c < 26; c++) {
            int charValue = c + 1; // 'a' -> 1, 'b' -> 2, ..., 'z' -> 26
            
            // Process all occurrences of this character
            while (counts[c] > 0) {
                // Contribution of this character = (value * 26^i) % MOD
                long contribution = (charValue * pow26) % MOD;
                totalScore = (totalScore + contribution) % MOD;
                
                // Advance to the next power of 26 for the next index
                pow26 = (pow26 * 26) % MOD;
                counts[c]--;
            }
        }
        
        return (int) totalScore;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            String s = scanner.next();
            int result = calculate_max_score(n, s);
            System.out.println(result);
        }
        scanner.close();
    }
}
