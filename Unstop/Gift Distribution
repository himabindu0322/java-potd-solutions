import java.util.*;

public class Main {
    public static class Result {
        boolean isPossible;
        List<Integer> set1;
        List<Integer> set2;

        Result(boolean isPossible, List<Integer> set1, List<Integer> set2) {
            this.isPossible = isPossible;
            this.set1 = set1;
            this.set2 = set2;
        }

        static Result notPossible() {
            return new Result(false, null, null);
        }
    }

    public static Result userLogic(int n) {
        // Calculate total sum using long to avoid integer overflow for N = 10^6
        long totalSum = (long) n * (n + 1) / 2;

        // If the total sum is odd, it's impossible to divide into two equal integer sums
        if (totalSum % 2 != 0) {
            return Result.notPossible();
        }

        long target = totalSum / 2;
        List<Integer> set1 = new ArrayList<>();
        List<Integer> set2 = new ArrayList<>();

        // Greedy distribution from N down to 1
        for (int i = n; i >= 1; i--) {
            if (target >= i) {
                set1.add(i);
                target -= i;
            } else {
                set2.add(i);
            }
        }

        return new Result(true, set1, set2);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int n = scanner.nextInt();

        Result result = userLogic(n);

        if (result.isPossible) {
            System.out.println("YES");

            System.out.println(result.set1.size());
            for (int num : result.set1) {
                System.out.print(num + " ");
            }
            System.out.println();

            System.out.println(result.set2.size());
            for (int num : result.set2) {
                System.out.print(num + " ");
            }
            System.out.println();
        } else {
            System.out.println("NO");
        }

        scanner.close();
    }
}
