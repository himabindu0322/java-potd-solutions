import java.util.*;

public class Main {
    public static int[] smallerNumbersThanCurrent(int[] nums) {
        // Since max value of nums[i] is 100 according to constraints, a size 102 array handles 0-101 safely.
        int[] countBuckets = new int[102];
        
        // Step 1: Count frequency of each number
        for (int num : nums) {
            countBuckets[num]++;
        }
        
        // Step 2: Convert frequencies into a running prefix sum
        // runningSum tracks the number of elements strictly smaller than the current index `i`
        int runningSum = 0;
        int[] smallerThan = new int[102];
        for (int i = 0; i <= 100; i++) {
            smallerThan[i] = runningSum;
            runningSum += countBuckets[i];
        }
        
        // Step 3: Map the original numbers to their computed smaller counts
        int[] result = new int[nums.length];
        for (int i = 0; i < nums.length; i++) {
            result[i] = smallerThan[nums[i]];
        }
        
        return result;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] nums = new int[n];
            for (int i = 0; i < n; i++) {
                nums[i] = scanner.nextInt();
            }
            
            int[] result = smallerNumbersThanCurrent(nums);
            for (int i = 0; i < result.length; i++) {
                System.out.print(result[i] + " ");
            }
            System.out.println();
        }
        scanner.close();
    }
}
