import java.util.Scanner;

public class Main {
    public static int findMinimumK(int a, int b, int c) {
        // Use long to prevent integer overflow during multiplication
        long prod = 4L * a * c;
        
        // If 4AC <= 0, the inequality (B-K)^2 >= 4AC is unconditionally true for K = 0
        if (prod <= 0) {
            return 0;
        }

        double sqrtVal = Math.sqrt(prod);
        
        // Find the boundary integers for both regions
        long k1 = (long) Math.floor(b - sqrtVal);
        long k2 = (long) Math.ceil(b + sqrtVal);

        // Find the minimum absolute value in the first region (K <= k1)
        long ans1 = (k1 >= 0) ? 0 : Math.abs(k1);

        // Find the minimum absolute value in the second region (K >= k2)
        long ans2 = (k2 <= 0) ? 0 : Math.abs(k2);

        // Return the best option from both valid regions
        return (int) Math.min(ans1, ans2);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int T = scanner.nextInt();
            int[] results = new int[T];
            for (int i = 0; i < T; i++) {
                int a = scanner.nextInt();
                int b = scanner.nextInt();
                int c = scanner.nextInt();
                results[i] = findMinimumK(a, b, c);
            }
            for (int result : results) {
                System.out.println(result);
            }
        }
        scanner.close();
    }
}
