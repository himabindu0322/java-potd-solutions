import java.util.*;

public class Main {
    public static int max_jamun(int[] arr) {
        if (arr == null || arr.length == 0) {
            return 0;
        }
        int n = arr.length;
        if (n == 1) {
            return arr[0];
        }

        // Space-optimized DP state tracking variables
        int prev2 = 0;
        int prev1 = arr[0];

        for (int i = 1; i < n; i++) {
            // Option 1: Pick current element + best from i-2
            int pick = arr[i] + prev2;
            // Option 2: Skip current element and take best from i-1
            int skip = prev1;

            int current = Math.max(pick, skip);
            
            // Shift states for next iteration
            prev2 = prev1;
            prev1 = current;
        }

        return prev1;
    }
    
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        int n = scanner.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = scanner.nextInt();
        }
        int result = max_jamun(arr);
        System.out.println(result);
        scanner.close();
    }
}
