import java.io.*;
import java.util.*;

class Main {
    private static final int MAX_VAL = 100000;
    private static final boolean[] isPrime = new boolean[MAX_VAL + 1];

    // Precompute prime numbers up to 10^5 using Sieve of Eratosthenes
    static {
        Arrays.fill(isPrime, true);
        isPrime[0] = false;
        isPrime[1] = false;

        for (int p = 2; p * p <= MAX_VAL; p++) {
            if (isPrime[p]) {
                for (int i = p * p; i <= MAX_VAL; i += p) {
                    isPrime[i] = false;
                }
            }
        }
    }

    static String processQueries(int q, int[] queries) {
        StringBuilder sb = new StringBuilder(q);
        for (int i = 0; i < q; i++) {
            if (isPrime[queries[i]]) {
                sb.append('1');
            } else {
                sb.append('0');
            }
        }
        return sb.toString();
    }

    public static void main(String[] args) throws IOException {
        // Fast I/O for 10^5 inputs
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        
        String line = br.readLine();
        if (line == null || line.trim().isEmpty()) return;
        
        int q = Integer.parseInt(line.trim());
        int[] queries = new int[q];

        StringTokenizer st = new StringTokenizer(br.readLine());
        for (int i = 0; i < q; i++) {
            queries[i] = Integer.parseInt(st.nextToken());
        }

        String result = processQueries(q, queries);
        System.out.println(result);
    }
}
