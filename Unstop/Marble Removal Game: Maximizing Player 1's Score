import java.util.Scanner;

public class Main {
    public static int removeMarbles(int n, int k, int[] sequence) {
        // dp[i] stores the max marbles the current player can get if the pile has i marbles remaining.
        int[] dp = new int[n + 1];

        // Base case: 0 marbles left means 0 marbles can be removed
        dp[0] = 0;

        // Build the DP table from 1 up to N marbles
        for (int i = 1; i <= n; i++) {
            int maxMarbles = 0;
            
            // Try every allowed move from the sequence
            for (int j = 0; j < k; j++) {
                int move = sequence[j];
                
                if (move <= i) {
                    // Marbles current player gets = total current marbles - what opponent gets in the next state
                    int currentTurnGain = i - dp[i - move];
                    if (currentTurnGain > maxMarbles) {
                        maxMarbles = currentTurnGain;
                    }
                }
            }
            dp[i] = maxMarbles;
        }

        // Return the max marbles Player 1 can secure starting with N marbles
        return dp[n];
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int k = scanner.nextInt();
            int[] sequence = new int[k];
            for (int i = 0; i < k; i++) {
                sequence[i] = scanner.nextInt();
            }
            int result = removeMarbles(n, k, sequence);
            System.out.println(result);
        }
        scanner.close();
    }
}
