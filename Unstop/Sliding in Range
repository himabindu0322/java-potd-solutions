import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int n = scanner.nextInt();
        int l = scanner.nextInt();
        int r = scanner.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = scanner.nextInt();
        }
        System.out.println(numSubarrayBoundedMax(arr, l, r));
        scanner.close();
    }

    public static int numSubarrayBoundedMax(int[] A, int L, int R) {
        return countMaxLessThanOrEqual(A, R) - countMaxLessThanOrEqual(A, L - 1);
    }
    
    // Helper method to count contiguous subarrays whose maximum element is <= bound
    private static int countMaxLessThanOrEqual(int[] A, int bound) {
        int count = 0;
        int currentLength = 0;
        
        for (int num : A) {
            if (num <= bound) {
                currentLength++;
                count += currentLength;
            } else {
                currentLength = 0;
            }
        }
        
        return count;
    }
}
