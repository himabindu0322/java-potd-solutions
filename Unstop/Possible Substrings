import java.util.Scanner;
import java.util.HashSet;

public class Main {
    public static int user_logic(String s) {
        // If the string length is less than 2, no substring of length 2 can be formed.
        if (s == null || s.length() < 2) {
            return 0;
        }

        // Set to store unique substrings of length 2
        HashSet<String> uniqueSubstrings = new HashSet<>();

        // Iterate through the string up to the second to last character
        for (int i = 0; i < s.length() - 1; i++) {
            String substring = s.substring(i, i + 2);
            uniqueSubstrings.add(substring);
        }

        // The size of the set represents the count of unique substrings
        return uniqueSubstrings.size();
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int T = scanner.nextInt();
        scanner.nextLine(); // Consume the remaining newline character
        int[] results = new int[T];
        
        for (int i = 0; i < T; i++) {
            if (scanner.hasNextLine()) {
                String S = scanner.nextLine();
                results[i] = user_logic(S);
            }
        }
        
        for (int res : results) {
            System.out.println(res);
        }
        scanner.close();
    }
}
