import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int N = scanner.nextInt();
            int result = user_logic(N);
            System.out.println(result);
        }
    }

    public static int user_logic(int N) {
        // Base case: If N is 0, the power received is 0
        if (N == 0) {
            return 0;
        }
        // Base case: If N is 1, the power received is 1
        if (N == 1) {
            return 1;
        }

        // Initialize values on the papers
        int paper1 = 0;
        int paper2 = 1;

        // Perform the process for N - 1 iterations
        for (int i = 0; i < N - 1; i++) {
            int sum = paper1 + paper2;
            paper1 = paper2;
            paper2 = sum;
        }

        return paper2;
    }
}
