import java.util.*;

public class Main {
    static final int MOD = 1000007;

    // Extended Euclidean Algorithm to find modular inverse
    private static int modInverse(int a, int m) {
        int m0 = m;
        int y = 0, x = 1;

        if (m == 1) return 0;

        while (a > 1) {
            // q is quotient
            int q = a / m;
            int t = m;

            // m is remainder now, process same as Euclid's algo
            m = a % m;
            a = t;
            t = y;

            // Update y and x
            y = x - q * y;
            x = t;
        }

        // Make x positive
        if (x < 0) x += m0;

        return x;
    }

    public static int calculateInverseOfLISLength(int n, List<Integer> heights) {
        if (n == 0) return 0;

        // Step 1: Compute Longest Increasing Subsequence (LIS)
        List<Integer> tails = new ArrayList<>();

        for (int height : heights) {
            int pos = Collections.binarySearch(tails, height);
            
            if (pos < 0) {
                pos = -(pos + 1);
            }

            if (pos == tails.size()) {
                tails.add(height);
            } else {
                tails.set(pos, height);
            }
        }

        int lisLength = tails.size(); // In the sample case, LIS length = 4

        // Step 2: Compute inverse of LIS length under MOD = 1000007
        return modInverse(lisLength, MOD);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            List<Integer> heights = new ArrayList<>(n);
            for (int i = 0; i < n; i++) {
                heights.add(scanner.nextInt());
            }
            int result = calculateInverseOfLISLength(n, heights);
            System.out.println(result);
        }
        scanner.close();
    }
}
