import java.util.*;

public class Solution {
    public static Queue<Integer> reverseElements(Queue<Integer> q, int k) {
        // Edge case: If k is 0 or greater than the size, no change is needed
        if (q == null || k <= 0 || k > q.size()) {
            return q;
        }

        Stack<Integer> stack = new Stack<>();
        int n = q.size();

        // Step 1: Push first K elements into the stack
        for (int i = 0; i < k; i++) {
            stack.push(q.poll());
        }

        // Step 2: Enqueue the elements back from the stack to the queue
        while (!stack.isEmpty()) {
            q.add(stack.pop());
        }

        // Step 3: Rotate the remaining (N - K) elements to the back
        for (int i = 0; i < n - k; i++) {
            q.add(q.poll());
        }

        return q;
    }
}
