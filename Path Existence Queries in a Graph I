class Solution {
    public boolean[] pathExistenceQueries(int n, int[] nums, int maxDiff, int[][] queries) {
        // Step 1: Group nodes into connected components
        int[] componentId = new int[n];
        int currentId = 0;
        componentId[0] = currentId;
        
        for (int i = 1; i < n; i++) {
            // If the jump to the next element exceeds maxDiff, it breaks the component
            if (nums[i] - nums[i - 1] > maxDiff) {
                currentId++;
            }
            componentId[i] = currentId;
        }
        
        // Step 2: Answer each query in O(1) time
        boolean[] answer = new boolean[queries.length];
        for (int i = 0; i < queries.length; i++) {
            int u = queries[i][0];
            int v = queries[i][1];
            
            // If both nodes belong to the same component, a path exists
            answer[i] = (componentId[u] == componentId[v]);
        }
        
        return answer;
    }
}
