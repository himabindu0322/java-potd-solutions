import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc = new Scanner(System.in);
		
		// Read N (number of children) and C (total candies)
		int N = sc.nextInt();
		long C = sc.nextLong(); // Long to handle large total values securely
		
		long totalRequired = 0;
		for (int i = 0; i < N; i++) {
			totalRequired += sc.nextInt();
		}
		
		// Check if Chef has enough candies to satisfy the minimum requirements
		if (C >= totalRequired) {
			System.out.println("Yes");
		} else {
			System.out.println("No");
		}
		
		sc.close();
	}
}
